# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/memcore
REDIS_URL=redis://localhost:6379/0

# Server
PORT=8000

# LLM Providers (need at least one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
COHERE_API_KEY=

# MiniMax — canonical hosted LLM baseline for `pnpm eval:minimax`. MiniMax is
# OpenAI-compatible chat-completions at https://api.minimaxi.chat/v1 (no
# embeddings, no rerank). The eval script overlays LLM_BASE_URL +
# EXTRACTION_MODEL/etc with these. Embeddings still come from LOCAL_* below.
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
# MINIMAX_LLM_MODEL=MiniMax-M2.7
# MINIMAX_ABSTAIN_SIMILARITY_FLOOR=0.55

# Embedding endpoint (any OpenAI-compatible /v1/embeddings: LMStudio, Ollama,
# vLLM, OpenAI). Leave EMBEDDING_BASE_URL unset to use the public OpenAI API
# with OPENAI_API_KEY. EMBEDDING_API_KEY overrides OPENAI_API_KEY when set —
# useful for LMStudio (any string works) or routing to a different account.
# EMBEDDING_BASE_URL=http://localhost:1234/v1
# EMBEDDING_API_KEY=lm-studio

# Local-stack test client (scripts/test-client.ts) defaults to Ollama on :11434.
# These LOCAL_* vars are namespaced so they don't collide with the project's
# OpenAI-targeted EMBEDDING_* vars above. Override to point at LMStudio
# (:1234), vLLM, or any other OpenAI-shaped endpoint.
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LOCAL_LLM_API_KEY=ollama
# LOCAL_LLM_MODEL=qwen2.5:7b
# LOCAL_EMBEDDING_BASE_URL=http://localhost:11434/v1
# LOCAL_EMBEDDING_API_KEY=ollama
# LOCAL_EMBEDDING_MODEL=nomic-embed-text
# LOCAL_ABSTAIN_SIMILARITY_FLOOR=0.55   # raise for nomic; 0.3 fits text-embedding-3-large
# MEMCORE_TEST_TAG=local-test

# Model selection
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
# Extraction defaults to OpenAI's chat-completions wire format (gpt-4o-mini is
# the cheap default). To use claude-haiku-4-5 / claude-sonnet-4-6 you must
# inject an Anthropic-shaped LLMClient — see SDK docs.
EXTRACTION_MODEL=gpt-4o-mini
CONFLICT_MODEL=gpt-4o
CONTEXTUALIZER_MODEL=gpt-4o-mini
RERANKER_PROVIDER=cohere

# Ingestion tuning
SESSION_INACTIVITY_MINUTES=30
SESSION_LENGTH_THRESHOLD=20
CHUNK_MIN_TOKENS=100
CHUNK_MAX_TOKENS=800
CHUNK_TOPIC_SHIFT_THRESHOLD=0.35

# Retrieval tuning
RRF_K=60

# Logging
LOG_LEVEL=info

# Dev
ENVIRONMENT=development
API_KEY_DEV=dev-key
